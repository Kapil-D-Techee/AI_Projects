# Copy this file to .env and fill in real values. Never commit the real .env file.
#
# LLM_MODEL / STT_MODEL / TTS_MODEL / TTS_VOICE_ID / SARVAM_VOICE_NAME are
# OPTIONAL overrides. If you leave them blank/unset, the app picks the right
# default automatically based on LLM_PROVIDER / STT_PROVIDER / TTS_PROVIDER
# (see backend/app/config/providers.py) — so flipping just the provider is
# enough to fully switch vendors.

# --- LLM (default: Groq Llama 3.3 70B Versatile) ---------------------------
GROQ_API_KEY=your_groq_api_key_here
LLM_PROVIDER=groq
# LLM_MODEL=                 # leave unset to auto-pick per provider
LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=700

# To switch the LLM to OpenAI instead, set:
#   LLM_PROVIDER=openai
#   (LLM_MODEL auto-picks gpt-4o-mini; set LLM_MODEL=gpt-4o for the full model)
OPENAI_API_KEY=your_openai_api_key_here

# --- Sarvam AI (default STT + TTS — Indian-language tuned) -----------------
# Get a key at https://www.sarvam.ai/ . Used for both speech-to-text
# (saaras:v3, handles Tamil/English code-mixed speech well) and text-to-speech
# (bulbul:v3, Indian-accent voices) by default.
SARVAM_API_KEY=your_sarvam_api_key_here

# --- STT (default: Sarvam saaras:v3, mode=codemix) --------------------------
STT_PROVIDER=sarvam
# STT_MODEL=                 # leave unset to auto-pick per provider (saaras:v3)

# To switch STT to Groq-hosted Whisper instead, set:
#   STT_PROVIDER=groq_whisper
#   Reuses GROQ_API_KEY by default; set GROQ_WHISPER_API_KEY only if you want
#   a different key/account for STT than for the LLM.
GROQ_WHISPER_API_KEY=

# To switch STT to OpenAI's Whisper instead, set:
#   STT_PROVIDER=openai_whisper
#   (STT_MODEL auto-picks whisper-1; uses OPENAI_API_KEY above, no Groq key needed)

# --- TTS (default: Sarvam bulbul:v3) ----------------------------------------
TTS_PROVIDER=sarvam
# TTS_MODEL=                 # leave unset to auto-pick per provider (bulbul:v3)
SARVAM_VOICE_NAME=Pooja      # Sarvam speaker name; leave unset to default to "pooja"
#   Other Sarvam speakers: shubh, aditya, ritu, priya, neha, rahul, rohan,
#   simran, kavya, amit, dev, ishita, shreya, kabir, anand, tanya, ...
SARVAM_LANGUAGE_CODE=ta-IN   # native Tamil voice/accent; leave unset to default to "ta-IN"
#SARVAM_LANGUAGE_CODE=en-IN  # English-accented voice — cleaner for English/maths terms,
                             # but loses the native-Tamil feel for Tanglish replies
SARVAM_TEMPERATURE=1.0       # expressiveness, 0.01-2.0; higher = warmer/more emotional,
                             # but can introduce instability/artifacts above ~1.3-1.5

# To switch TTS to ElevenLabs Flash v2.5 instead, set:
#   TTS_PROVIDER=elevenlabs
#   TTS_VOICE_ID=<your ElevenLabs voice id>
# NOTE: ElevenLabs free-tier accounts get a 402 "paid_plan_required" error on
# ANY shared/library voice via the API (including voices shown in your own
# "My Voices" tab if they were added from the library, not cloned/generated
# by you). If you hit that error, either upgrade your ElevenLabs plan, or
# clone/generate a voice that's truly yours, or use TTS_PROVIDER=browser below.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Free fallback with no API key / no account restrictions — uses the
# browser's built-in SpeechSynthesis instead of calling any TTS API:
# TTS_PROVIDER=browser

# Reserved for a future Tamil-voice fallback via Google Cloud TTS:
GOOGLE_CLOUD_TTS_CREDENTIALS_PATH=

# --- Session storage (conversation history + staged-solution stages) ------
# Leave both UNSET for local development — the app falls back to a simple
# in-memory store automatically (see backend/app/services/session_store.py).
# REQUIRED in production on Vercel: Vercel's Python runtime is serverless
# (each request may hit a different/cold instance), so in-memory storage
# would lose conversation history and staged-solution progress unpredictably.
# Connect an Upstash Redis integration from the Vercel Marketplace to your
# project and these two get injected automatically — no need to set them
# by hand if deploying on Vercel.
# RECOMMENDED on Render: the free tier sleeps the instance after 15min idle,
# so in-memory storage loses conversation history and staged-solution
# progress on every cold start (30-60s to wake) — same issue as Vercel.
# Set these (Upstash account separately at upstash.com; Render has no
# built-in Marketplace integration like Vercel's) to avoid that.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
